{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Jira Log",
  "type": "object",
  "required": ["lastSyncAt", "activeTickets", "pendingActions", "syncHistory"],
  "properties": {
    "lastSyncAt": {"type": ["string", "null"], "format": "date-time"},
    "lastSyncStatus": {
      "type": ["string", "null"],
      "enum": ["success", "error", null]
    },
    "activeTickets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["id", "summary", "status"],
        "properties": {
          "id": {"type": "string"},
          "summary": {"type": "string"},
          "status": {"type": "string"},
          "statusMapped": {"type": "string"},
          "priority": {"type": "string"},
          "priorityMapped": {"type": "string"},
          "dueDate": {"type": ["string", "null"]},
          "url": {"type": "string"},
          "lastSeen": {"type": "string", "format": "date-time"},
          "project": {"type": "string"}
        }
      }
    },
    "pendingActions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["action", "ticket", "addedAt"],
        "properties": {
          "action": {"type": "string"},
          "ticket": {"type": "string"},
          "summary": {"type": "string"},
          "addedAt": {"type": "string", "format": "date-time"},
          "surfacedAt": {
            "type": ["string", "null"],
            "format": "date-time"
          }
        }
      }
    },
    "syncHistory": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": {"type": "string", "format": "date-time"},
          "ticketsFetched": {"type": "integer"},
          "added": {"type": "integer"},
          "updated": {"type": "integer"},
          "closed": {"type": "integer"},
          "status": {"type": "string"},
          "changes": {"type": "array"},
          "errors": {"type": "array"}
        }
      }
    }
  }
}
