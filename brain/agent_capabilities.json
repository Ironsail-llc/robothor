{
  "version": "1.0.0",
  "description": "Agent RBAC manifest — declares what each agent can access via Bridge (:9100)",
  "default_policy": "allow",
  "agents": {
    "email-classifier": {
      "description": "Classifies and routes emails",
      "tools": ["list_conversations", "log_interaction", "create_person", "create_task", "list_tasks", "list_my_tasks", "resolve_task", "update_task", "append_to_block"],
      "bridge_endpoints": ["GET /health", "GET /api/conversations", "POST /log-interaction", "POST /api/people", "POST /api/tasks", "GET /api/tasks", "PATCH /api/tasks/*", "GET /api/tasks/agent/*", "POST /api/tasks/*/resolve", "POST /api/memory/blocks/*/append"],
      "streams_read": ["email"],
      "streams_write": []
    },
    "calendar-monitor": {
      "description": "Monitors calendar changes and conflicts",
      "tools": ["log_interaction", "create_task", "list_my_tasks", "resolve_task", "append_to_block"],
      "bridge_endpoints": ["GET /health", "POST /log-interaction", "POST /api/tasks", "GET /api/tasks/agent/*", "POST /api/tasks/*/resolve", "POST /api/memory/blocks/*/append"],
      "streams_read": ["calendar"],
      "streams_write": []
    },
    "email-analyst": {
      "description": "Analyzes complex emails for structured response",
      "tools": ["create_task", "list_my_tasks", "resolve_task", "update_task", "get_inbox", "ack_notification", "append_to_block"],
      "bridge_endpoints": ["GET /health", "POST /api/tasks", "PATCH /api/tasks/*", "GET /api/tasks/agent/*", "POST /api/tasks/*/resolve", "GET /api/notifications/inbox/*", "POST /api/notifications/*/ack", "POST /api/memory/blocks/*/append"],
      "streams_read": ["email"],
      "streams_write": []
    },
    "email-responder": {
      "description": "Composes and sends email replies",
      "tools": ["log_interaction", "create_person", "list_people", "create_task", "get_task", "list_my_tasks", "resolve_task", "update_task", "get_inbox", "ack_notification", "append_to_block"],
      "bridge_endpoints": ["GET /health", "POST /log-interaction", "POST /api/people", "GET /api/people", "POST /api/tasks", "GET /api/tasks/*", "PATCH /api/tasks/*", "GET /api/tasks/agent/*", "POST /api/tasks/*/resolve", "GET /api/notifications/inbox/*", "POST /api/notifications/*/ack", "POST /api/memory/blocks/*/append"],
      "streams_read": ["email"],
      "streams_write": []
    },
    "supervisor": {
      "description": "Audits pipeline health, surfaces escalations to the operator",
      "tools": ["list_conversations", "crm_health", "list_tasks", "get_task", "list_my_tasks", "resolve_task", "update_task", "approve_task", "reject_task", "send_notification", "get_inbox", "ack_notification", "append_to_block"],
      "bridge_endpoints": ["GET /health", "GET /api/conversations", "GET /api/tasks", "GET /api/tasks/*", "GET /api/tasks/agent/*", "POST /api/tasks/*/resolve", "PATCH /api/tasks/*", "POST /api/tasks/*/approve", "POST /api/tasks/*/reject", "POST /api/notifications/send", "GET /api/notifications/inbox/*", "POST /api/notifications/*/ack", "POST /api/memory/blocks/*/append"],
      "streams_read": ["email", "crm", "health", "agent", "calendar", "vision", "system"],
      "streams_write": []
    },
    "vision-monitor": {
      "description": "Monitors vision events, escalates anomalies",
      "tools": ["create_task", "list_my_tasks", "resolve_task", "append_to_block"],
      "bridge_endpoints": ["GET /health", "POST /api/tasks", "GET /api/tasks/agent/*", "POST /api/tasks/*/resolve", "POST /api/memory/blocks/*/append"],
      "streams_read": ["vision"],
      "streams_write": []
    },
    "conversation-inbox": {
      "description": "Checks for urgent unread messages",
      "tools": ["list_conversations", "list_messages", "toggle_conversation_status", "create_task", "get_inbox", "ack_notification", "append_to_block"],
      "bridge_endpoints": ["GET /health", "GET /api/conversations", "GET /api/conversations/*/messages", "POST /api/conversations/*/toggle_status", "POST /api/tasks", "GET /api/notifications/inbox/*", "POST /api/notifications/*/ack", "POST /api/memory/blocks/*/append"],
      "streams_read": ["crm"],
      "streams_write": []
    },
    "conversation-resolver": {
      "description": "Auto-resolves stale conversations",
      "tools": ["list_conversations", "list_messages", "toggle_conversation_status", "list_tasks", "get_inbox", "ack_notification", "append_to_block"],
      "bridge_endpoints": ["GET /health", "GET /api/conversations", "GET /api/conversations/*/messages", "POST /api/conversations/*/toggle_status", "GET /api/tasks", "GET /api/notifications/inbox/*", "POST /api/notifications/*/ack", "POST /api/memory/blocks/*/append"],
      "streams_read": ["crm"],
      "streams_write": []
    },
    "crm-steward": {
      "description": "CRM data hygiene, enrichment, duplicate merge",
      "tools": ["crm_health", "list_people", "update_person", "update_company", "merge_contacts", "merge_companies", "create_note", "create_task", "list_tasks", "list_my_tasks", "update_task", "resolve_task", "get_inbox", "ack_notification", "append_to_block"],
      "bridge_endpoints": ["GET /health", "GET /api/people", "PATCH /api/people/*", "PATCH /api/companies/*", "POST /api/people/merge", "POST /api/companies/merge", "POST /api/notes", "POST /api/tasks", "GET /api/tasks", "PATCH /api/tasks/*", "GET /api/tasks/agent/*", "POST /api/tasks/*/resolve", "GET /api/notifications/inbox/*", "POST /api/notifications/*/ack", "POST /api/memory/blocks/*/append"],
      "streams_read": ["crm"],
      "streams_write": ["crm"]
    },
    "morning-briefing": {
      "description": "Daily morning briefing to Telegram",
      "tools": ["list_conversations"],
      "bridge_endpoints": ["GET /health", "GET /api/conversations"],
      "streams_read": ["email", "calendar", "health"],
      "streams_write": []
    },
    "evening-winddown": {
      "description": "Daily evening review to Telegram",
      "tools": ["list_conversations"],
      "bridge_endpoints": ["GET /health", "GET /api/conversations"],
      "streams_read": ["email", "calendar", "health"],
      "streams_write": []
    },
    "helm-user": {
      "description": "Helm web dashboard (operator's interactive session)",
      "tools": ["list_conversations", "get_conversation", "list_messages", "create_message", "toggle_conversation_status", "log_interaction", "create_person", "list_people", "create_note", "update_person", "update_company", "merge_contacts", "merge_companies", "crm_health", "vault_list", "vault_get", "vault_search", "create_task", "update_task", "get_task", "delete_task", "list_tasks", "list_my_tasks", "resolve_task", "approve_task", "reject_task", "send_notification", "get_inbox", "ack_notification"],
      "bridge_endpoints": ["GET /health", "GET /api/*", "POST /api/*", "PATCH /api/*", "PUT /api/*", "DELETE /api/*"],
      "streams_read": ["email", "crm", "health", "agent", "calendar", "vision", "system"],
      "streams_write": []
    }
  }
}
