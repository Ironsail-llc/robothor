# Symlinked directories (tracked in their own repos)
/templates/
/tunnel/

# Business adapters (local MCP server configs — not part of the public repo)
/adapters/

# Instance CLAUDE.md lives at brain/CLAUDE.md (covered by brain/*.md pattern below)
# Root CLAUDE.md is the tracked platform rules file.

# Instance data — user-land config created by `genusos init`, never part of platform
# Agent manifests and instruction files
brain/*.md
brain/*.bak
!brain/README.md
brain/agents/
brain/instructions/
brain/scripts/
brain/memory/
docs/agents/*.yaml
docs/agents/*.md
docs/agents/retired/
!docs/agents/schema.yaml
!docs/agents/INSTRUCTION_CONTRACT.md
!docs/agents/GOAL_TAXONOMY.md
!docs/agents/corrective-actions.yaml
docs/CRON_MAP.md
docs/experiments/
docs/workflows/retired/

# Instance runtime state (root memory/ is agent working data)
memory/

# Backup logs
scripts/backup.log

