# Copy to local/owner.env and fill in your values (gitignored).
#
# These are resolved at manifest load time via ${VAR_NAME} syntax.
# In production, SOPS decrypts secrets to /run/robothor/secrets.env
# which systemd loads via EnvironmentFile=.

# ── Identity ───────────────────────────────────────────────────────────────
ROBOTHOR_OWNER_NAME=
ROBOTHOR_OWNER_EMAIL=
ROBOTHOR_AI_EMAIL=
ROBOTHOR_TIMEZONE=America/New_York

# ── Telegram ───────────────────────────────────────────────────────────────
ROBOTHOR_TELEGRAM_CHAT_ID=
ROBOTHOR_TELEGRAM_BOT_TOKEN=
